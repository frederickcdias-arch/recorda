# Database Configuration
# Option 1 (recommended in cloud): provide DATABASE_URL
# DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2 (local/dev): provide DB_*
DB_HOST=localhost
DB_PORT=5433
DB_NAME=recorda
DB_USER=recorda
DB_PASSWORD=recorda

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Environment
NODE_ENV=development

# CORS / App URLs (production)
# CORS_ORIGIN=https://recorda.vercel.app
# APP_URL=https://recorda.vercel.app

# JWT Configuration (REQUIRED)
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-change-in-production

# Frontend (Vercel)
# VITE_API_BASE=https://recorda-api.up.railway.app

# Frontend (dev local proxy target)
# VITE_DEV_API_TARGET=http://localhost:3000

# Email sender (SMTP)
# SMTP_FROM=noreply@seu-dominio.com
