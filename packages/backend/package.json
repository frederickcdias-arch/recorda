{
  "name": "@recorda/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/infrastructure/database/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --reporter=verbose src/**/*.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@recorda/shared": "*",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.7.4",
    "fastify-plugin": "^4.5.1",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.0",
    "@types/redis": "^4.0.11",
    "fast-check": "^4.5.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
