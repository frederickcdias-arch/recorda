# ============================================
# Recorda Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED in prod] must be set for production.

# ── General ──────────────────────────────────
NODE_ENV=development          # development | staging | production
TZ=America/Sao_Paulo

# ── Server ───────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Database ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=recorda
DB_USER=recorda
DB_PASSWORD=recorda           # [REQUIRED in prod]

# ── Authentication ───────────────────────────
JWT_SECRET=change-me-to-a-random-secret   # [REQUIRED in prod] min 32 chars

# ── CORS ─────────────────────────────────────
CORS_ORIGIN=https://recorda.local   # [REQUIRED in prod] frontend URL

# ── Application URL (used in emails) ────────
APP_URL=http://localhost:5173       # [REQUIRED in prod] e.g. https://recorda.local

# ── Email (SMTP) ─────────────────────────────
# If SMTP_HOST is not set, emails are logged to console (dev mode).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false             # true for port 465
# SMTP_USER=user@example.com
# SMTP_PASS=secret
# SMTP_FROM=noreply@recorda.local

# ── Database SSL (production) ─────────────────────
# DB_SSL=false                  # Set to 'false' to disable SSL in production
# DB_SSL_REJECT_UNAUTHORIZED=false  # Set to 'false' for self-signed certs

# ── Debug ────────────────────────────────────────
# RECORDA_IMPORT_DEBUG=1        # Enable import debug logging
