{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@recorda/shared": ["../shared/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/application/services",
    "src/domain",
    "src/infrastructure/analytics",
    "src/infrastructure/backup",
    "src/infrastructure/blockchain",
    "src/infrastructure/cache",
    "src/infrastructure/cdn",
    "src/infrastructure/compliance",
    "src/infrastructure/data-governance",
    "src/infrastructure/datalakes",
    "src/infrastructure/edgeai",
    "src/infrastructure/graphql",
    "src/infrastructure/microfrontends",
    "src/infrastructure/ml",
    "src/infrastructure/monitoring",
    "src/infrastructure/multi-tenant",
    "src/infrastructure/realtime",
    "src/infrastructure/repositories",
    "src/infrastructure/security",
    "src/infrastructure/serverless",
    "src/infrastructure/servicemesh"
  ]
}
