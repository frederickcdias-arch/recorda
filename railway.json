{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build --workspace=@recorda/shared && npm run build --workspace=@recorda/backend"
  },
  "deploy": {
    "startCommand": "npm run start --workspace=@recorda/backend",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120
  }
}
